# Copy to .env.local for local development
DATABASE_URL="postgresql://ii:ii@localhost:5434/instructional_integrity"
NODE_ENV="development"
LOG_LEVEL="info"
MAX_UPLOAD_SIZE_BYTES="5242880"
MAX_PASTE_LENGTH="100000"
EVALUATION_TIMEOUT_MS="30000"
# Max in-flight evaluations per server instance (§19.1)
MAX_CONCURRENT_EVALUATIONS="5"
# Optional comma-separated extra browser origins allowed to call /api (§12.2). Same origin always allowed.
# CORS_ALLOWED_ORIGINS="https://app.example.com"
