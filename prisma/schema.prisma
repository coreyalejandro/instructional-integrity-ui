generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Anonymous browser session (§29). No PII.
model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  artifacts      Artifact[]
  evaluationRuns EvaluationRun[]
  pendingUploads PendingUpload[]
  deletionLogs   DeletionLog[]
}

model Artifact {
  id         String         @id @default(cuid())
  sessionId  String
  title      String?
  rawText    String         @db.Text
  sourceType ArtifactSource
  mimeType   String?
  sampleId   String?

  session Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  runs    EvaluationRun[]

  createdAt DateTime @default(now())
}

model EvaluationRun {
  id                   String    @id @default(cuid())
  sessionId            String
  artifactId           String
  status               RunStatus
  verdict              Verdict
  overallScore         Float
  rubricVersion        String
  evaluatorId          String
  evaluatorVersion     String
  evaluationDurationMs Int
  failureClassSummary  String[]
  incompleteReason     String?

  session  Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  criteria CriterionResult[]

  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

model CriterionResult {
  id                   String           @id @default(cuid())
  evaluationRunId      String
  dimensionId          String
  score                Float
  maxScore             Float
  verdict              CriterionVerdict
  remediation          String           @db.Text
  evidenceInsufficient Boolean          @default(false)

  run EvaluationRun @relation(fields: [evaluationRunId], references: [id], onDelete: Cascade)

  evidence       EvidenceExcerpt[]
  failureClasses FailureClassRecord[]
}

model EvidenceExcerpt {
  id                String @id @default(cuid())
  criterionResultId String
  excerptText       String @db.Text
  location          String
  relevance         String @db.Text

  criterion CriterionResult @relation(fields: [criterionResultId], references: [id], onDelete: Cascade)
}

model FailureClassRecord {
  id                String @id @default(cuid())
  criterionResultId String
  classId           String

  criterion CriterionResult @relation(fields: [criterionResultId], references: [id], onDelete: Cascade)
}

model SampleArtifact {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  content     String @db.Text
  description String?
}

/// Temporary storage for upload → evaluate flow (§14).
model PendingUpload {
  id        String   @id @default(cuid())
  sessionId String
  title     String?
  content   String   @db.Text
  mimeType  String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model DeletionLog {
  id            String   @id @default(cuid())
  sessionId     String
  deletedRunIds String[]
  deletedAt     DateTime @default(now())
  metadata      Json?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum ArtifactSource {
  PASTE
  UPLOAD
  SAMPLE
}

enum RunStatus {
  COMPLETE
  INCOMPLETE
}

enum Verdict {
  PASS
  WARN
  FAIL
  NEEDS_HUMAN_REVIEW
}

enum CriterionVerdict {
  PASS
  WARN
  FAIL
}
